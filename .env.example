QUOTE_PROVIDER=finnhub
FINNHUB_API_KEY=your_finnhub_api_key_here

# US stocks: Finnhub free tier.
# A-shares: Eastmoney public quote endpoint, no key required.
# Keep polling modest on free/public sources.
QUOTE_REFRESH_SECONDS=60

# DeepSeek investment advisor. Keep this key only on the server.
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-v4-flash
# Keep false to save tokens. Set true only if you want every news refresh summarized by DeepSeek.
DEEPSEEK_AUTO_INTEL=false
